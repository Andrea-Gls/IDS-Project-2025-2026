### ===================================================================
### TEST MIRATO: TEAM, INVITI E ISCRIZIONE
### ===================================================================

### ---------------------------------------------------
### 1. SETUP ATTORI (Creiamo le persone)
### ---------------------------------------------------

### 1.1 Crea Organizzatore (Nick) - ID: 1
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{ "nome": "Nick", "cognome": "Fury", "email": "fury@shield.com", "password": "123" }

### 1.2 Crea Giudice (Matt) - ID: 2
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{ "nome": "Matt", "cognome": "Murdock", "email": "matt@law.com", "password": "123" }

### 1.3 Crea Mentore (Tony) - ID: 3
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{ "nome": "Tony", "cognome": "Stark", "email": "tony@stark.com", "password": "123" }

### 1.4 Crea Team Leader (Alice) - ID: 4
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{ "nome": "Alice", "cognome": "Wonder", "email": "alice@wonder.com", "password": "123" }

### 1.5 Crea Membro da Invitare (Bob) - ID: 5
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{ "nome": "Bob", "cognome": "Builder", "email": "bob@build.com", "password": "123" }


### ---------------------------------------------------
### 2. CREAZIONE HACKATHON (Il Contesto)
### ---------------------------------------------------

### 2.1 Crea Hackathon (Stato: ISCRIZIONI APERTE) - ID: 1
POST http://localhost:8080/api/hackathons/create
Content-Type: application/json

{
  "organizerId": 1,
  "judgeId": 2,
  "mentorIds": [3],
  "nome": "Java Cup 2026",
  "regolamento": "Codice pulito.",
  "luogo": "Online",
  "premio": 1000.0,
  "dimensioneMassimaTeam": 4,
  "dataInizio": "2026-10-01T09:00:00",
  "dataFine": "2026-10-03T18:00:00",
  "scadenzaIscrizione": "2026-09-30T23:59:00"
}

### ---------------------------------------------------
### 3. GESTIONE TEAM (Il cuore del problema)
### ---------------------------------------------------

### 3.1 Alice crea il Team - ID: 1
# Verifica: Alice deve diventare automaticamente membro.
POST http://localhost:8080/api/teams/create
Content-Type: application/json

{ "nomeTeam": "Super Coders", "creatorUserId": 4 }

### 3.2 Alice invita Bob (usando l'email)
# Verifica: Deve crearsi un invito "PENDING" nel DB.
POST http://localhost:8080/api/teams/invite
Content-Type: application/json

{
  "teamId": 1,
  "emailUtente": "bob@build.com"
}

### 3.3 Bob ACCETTA l'invito
# Verifica: L'invito diventa ACCEPTED e Bob entra nel team (field team_id su User).
POST http://localhost:8080/api/teams/respond-invite
Content-Type: application/json

{
  "teamId": 1,
  "userId": 5,
  "accetta": true
}

### ---------------------------------------------------
### 4. ISCRIZIONE ALL'EVENTO
### ---------------------------------------------------

### 4.1 Iscrizione del Team all'Hackathon
# Verifica: Deve controllare date, dimensione team e se sono già iscritti.
POST http://localhost:8080/api/registrations/join
Content-Type: application/json

{
  "hackathonId": 1,
  "teamId": 1,
  "userId": 4
}
# ATTESO: 200 OK - "Iscrizione effettuata con successo!"